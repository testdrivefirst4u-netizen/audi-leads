# MongoDB
MONGODB_URI=mongodb://localhost:27017/audi-dashboard

# Google Sheets service account
# Option A: path to the downloaded service account JSON key file (local dev only —
# this file is gitignored and never gets deployed, so it won't work on Vercel)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
# Option B: inline credentials, required on Vercel. Paste the private_key value
# from the JSON key file as-is, literal \n sequences included, in quotes.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Defaults used to seed Settings on first run (editable later from the Settings page)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Sheet1
SYNC_INTERVAL_MINUTES=1

PORT=3000

# Auth (change these before deploying anywhere shared)
AUTH_SECRET=replace-with-a-long-random-hex-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Secures /api/cron/sync — required on Vercel (see vercel.json). Vercel sends
# this automatically as "Authorization: Bearer <value>" for Cron invocations.
CRON_SECRET=replace-with-a-long-random-hex-string
