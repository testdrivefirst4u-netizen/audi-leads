# MongoDB
MONGODB_URI=mongodb://localhost:27017/audi-dashboard

# Google Sheets service account
# Option A: path to the downloaded service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
# Option B: inline credentials (used if the file above isn't found)
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Defaults used to seed Settings on first run (editable later from the Settings page)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Sheet1
SYNC_INTERVAL_MINUTES=1

PORT=3000

# Auth (change these before deploying anywhere shared)
AUTH_SECRET=replace-with-a-long-random-hex-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
